# ========================================================================
# ARCHIVO DE CONFIGURACIÓN DE ENTORNO (.env)
# ========================================================================
# Copia este archivo a .env y personaliza los valores según tu entorno
# NUNCA commits .env a git (ya debería estar en .gitignore)
# ========================================================================

# ========================================================================
# 1. ENTORNO (development / production)
# ========================================================================
ENVIRONMENT=development
# Para producción: ENVIRONMENT=production

# ========================================================================
# 2. DOMINIO / HOST
# ========================================================================
# El hostname del dispositivo se AGREGA AUTOMATICAMENTE
# DOMAIN_ALLOWED_HOSTS: hosts adicionales si es necesario

DOMAIN_MAIN=localhost
DOMAIN_ALLOWED_HOSTS=

# ========================================================================
# 3. PUERTOS (cambiar si entran en conflicto)
# ========================================================================
DJANGO_PORT=8001
REACT_PORT=3000
NGINX_PORT=80

# Para HTTPS en producción (nginx escucha en 443):
# NGINX_SSL_PORT=443

# ========================================================================
# 3B. URL API PARA FRONTEND REACT
# ========================================================================
# En desarrollo: localhost:8001 (Django sin Nginx)
# En producción: El mismo dominio (Nginx hace proxy /api -> Django)
REACT_APP_API_URL=http://localhost:8001/api

# ========================================================================
# 4. SECRET KEY de Django (CAMBIAR EN PRODUCCIÓN)
# ========================================================================
DJANGO_SECRET_KEY='AP9qJq)RR^A1JVIP!w-&c)0yp^I5+@whw&L9VYabYLr*vXZrHO'
# Generar una nueva con: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'

# ========================================================================
# 5. DEBUG (NUNCA True en producción)
# ========================================================================
DEBUG=True
# Para producción: DEBUG=False

# ========================================================================
# 6. CORS (Configuración de CORS_ALLOWED_ORIGINS)
# ========================================================================
# Para DESARROLLO (permite credenciales):
CORS_ALLOW_ALL_ORIGINS=False

# Para PRODUCCIÓN (específica los orígenes permitidos):
# CORS_ALLOWED_ORIGINS=https://empresa.com,https://www.empresa.com,https://admin.empresa.com

# ========================================================================
# 7. DATABASE (PostgreSQL)
# ========================================================================
DATABASE_ENGINE=django_tenants.postgresql_backend
DATABASE_NAME=mi_saas_db
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432

# Para producción con BD remota:
# DATABASE_HOST=db.tuservidor.com
# DATABASE_PASSWORD=PASSWORD_SUPER_SEGURO_AQUI

# ========================================================================
# 8. JWT TOKEN SETTINGS
# ========================================================================
JWT_ALGORITHM='HS256'
JWT_EXPIRATION_MINUTES=60
# Para producción: JWT_EXPIRATION_MINUTES=1440 (24 horas)

# ========================================================================
# 9. RUTAS Y ARCHIVOS ESTÁTICOS
# ========================================================================
STATIC_ROOT=/var/www/ecommerce/static
STATIC_URL=/static/
MEDIA_ROOT=/var/www/ecommerce/media
MEDIA_URL=/media/

# ========================================================================
# 10. CONFIGURACIÓN DE CORREO (GMAIL SSL)
# ========================================================================
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ========================================================================
# 11. TENANTS Y MULTI-DOMAIN
# ========================================================================
TENANT_MODEL=customers.Client
TENANT_DOMAIN_MODEL=customers.Domain

# ========================================================================
# 12. LOGGING (Opcional)
# ========================================================================
LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG (para desarrollo, mucho más verboso)

# ========================================================================
# 13. SECURITY (Producción)
# ========================================================================
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
